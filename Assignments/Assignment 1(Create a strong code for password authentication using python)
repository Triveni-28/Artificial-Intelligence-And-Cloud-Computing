import hashlib
import os
import re
import getpass

def hash_password(password, salt=None):
    if salt is None:
        salt = os.urandom(16)
    pwd_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000)
    return salt, pwd_hash

def verify_password(stored_salt, stored_hash, password):
    new_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), stored_salt, 100000)
    return new_hash == stored_hash

def is_strong(password):
    return (
        len(password) >= 12 and
        re.search(r"[A-Z]", password) and
        re.search(r"[a-z]", password) and
        re.search(r"[0-9]", password) and
        re.search(r"[!@#$%^&*(),.?\":{}|<>]", password)
    )

users = {}

def register():
    username = input("Username: ")
    password = getpass.getpass("Password: ")
    if not is_strong(password):
        print("Weak password")
        return
    salt, pwd_hash = hash_password(password)
    users[username] = (salt, pwd_hash)
    print("Registered")

def login():
    username = input("Username: ")
    password = getpass.getpass("Password: ")
    if username not in users:
        print("Invalid")
        return
    salt, pwd_hash = users[username]
    if verify_password(salt, pwd_hash, password):
        print("Access granted")
    else:
        print("Access denied")

while True:
    choice = input("1.Register 2.Login 3.Exit: ")
    if choice == "1":
        register()
    elif choice == "2":
        login()
    elif choice == "3":
        break
