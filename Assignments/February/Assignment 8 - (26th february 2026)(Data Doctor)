import pandas as pd

def load_data(file_path):
    return pd.read_csv(file_path)

def remove_duplicates(df):
    return df.drop_duplicates()

def handle_missing_values(df):
    for col in df.columns:
        if df[col].dtype == "object":
            df[col] = df[col].fillna("unknown")
        else:
            df[col] = df[col].fillna(df[col].mean())
    return df

def standardize_text(df):
    for col in df.columns:
        if df[col].dtype == "object":
            df[col] = df[col].astype(str).str.strip().str.lower()
    return df

def save_data(df, file_path):
    df.to_csv(file_path, index=False)

def main():
    input_file = "data.csv"
    output_file = "cleaned_data.csv"

    df = load_data(input_file)
    df = remove_duplicates(df)
    df = handle_missing_values(df)
    df = standardize_text(df)
    save_data(df, output_file)

    print("Cleaning Completed\n")
    print("Why Data Cleaning Matters:")
    print("1. Improves data quality and accuracy")
    print("2. Ensures consistency across the dataset")
    print("3. Prevents errors in analysis and models")
    print("4. Enhances model performance")
    print("5. Helps in better decision making")

if __name__ == "__main__":
    main()
