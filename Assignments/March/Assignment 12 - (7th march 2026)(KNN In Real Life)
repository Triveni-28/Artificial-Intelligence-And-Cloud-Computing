import numpy as np
from math import sqrt

def euclidean_distance(a, b):
    return sqrt(sum((x - y) ** 2 for x, y in zip(a, b)))

def get_neighbors(dataset, target, k):
    distances = []
    for name, features in dataset.items():
        dist = euclidean_distance(features, target)
        distances.append((name, dist))
    distances.sort(key=lambda x: x[1])
    return distances[:k]

def recommend(dataset, user_vector, k):
    neighbors = get_neighbors(dataset, user_vector, k)
    return [name for name, _ in neighbors]

def main():
    dataset = {
        "UserA": [5, 4, 0, 0, 3],
        "UserB": [4, 5, 0, 0, 4],
        "UserC": [0, 0, 5, 4, 2],
        "UserD": [0, 0, 4, 5, 1],
        "UserE": [5, 5, 1, 0, 4]
    }

    movies = ["Action1", "Action2", "Romance1", "Romance2", "Comedy1"]

    new_user = [5, 4, 0, 0, 0]

    print("\nUser Preference Vector:")
    print(dict(zip(movies, new_user)))

    k = 2
    neighbors = get_neighbors(dataset, new_user, k)

    print("\nNearest Neighbors:")
    for name, dist in neighbors:
        print(name, "Distance:", round(dist, 2))

    recommendations = recommend(dataset, new_user, k)

    print("\nRecommended Similar Users:")
    print(recommendations)

    print("\nExplanation:")
    print("KNN finds users with similar preferences using distance metrics.")
    print("Movies liked by similar users can be recommended to the new user.")
    print("This is similar to how streaming platforms suggest content.")

if __name__ == "__main__":
    main()
