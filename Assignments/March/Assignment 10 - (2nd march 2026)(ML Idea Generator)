import json

def get_ml_ideas():
    return [
        {"domain": "College", "problem": "Student Performance Prediction", "input": "Attendance, study hours, internal marks", "output": "Predicted final grade"},
        {"domain": "College", "problem": "Dropout Detection", "input": "Attendance, grades, engagement", "output": "Dropout risk level"},
        {"domain": "Healthcare", "problem": "Disease Prediction", "input": "Symptoms, medical history, lab reports", "output": "Likely disease"},
        {"domain": "Healthcare", "problem": "Heart Risk Analysis", "input": "Age, BP, cholesterol, lifestyle", "output": "Risk percentage"},
        {"domain": "Shopping", "problem": "Product Recommendation", "input": "User clicks, searches, purchases", "output": "Recommended products"},
        {"domain": "Shopping", "problem": "Demand Forecasting", "input": "Past sales, season, trends", "output": "Future demand"}
    ]

def display_ideas(ideas):
    print("\nML Idea Generator\n")
    for i, idea in enumerate(ideas, 1):
        print(f"{i}. Domain: {idea['domain']}")
        print(f"   Problem: {idea['problem']}")
        print(f"   Input: {idea['input']}")
        print(f"   Output: {idea['output']}\n")

def save_to_file(ideas, filename):
    with open(filename, "w") as f:
        json.dump(ideas, f, indent=4)

def load_from_file(filename):
    with open(filename, "r") as f:
        return json.load(f)

def main():
    ideas = get_ml_ideas()

    while True:
        print("1. Show ML Ideas")
        print("2. Save Ideas to File")
        print("3. Load Ideas from File")
        print("4. Exit")
        choice = input("Enter choice: ")

        if choice == "1":
            display_ideas(ideas)
        elif choice == "2":
            save_to_file(ideas, "ml_ideas.json")
            print("Saved successfully\n")
        elif choice == "3":
            try:
                ideas = load_from_file("ml_ideas.json")
                print("Loaded successfully\n")
            except:
                print("File not found\n")
        elif choice == "4":
            break
        else:
            print("Invalid choice\n")

if __name__ == "__main__":
    main()
